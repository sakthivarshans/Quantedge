# Database (SQLite for local dev if unset; Postgres in production)
# DATABASE_URL=postgresql://quantedge:quantedge@localhost:5432/quantedge

# Redis (used by Celery worker/beat for the scanner cache and background jobs)
# REDIS_URL=redis://localhost:6379/0

# Set true to skip live market data calls entirely and use the synthetic (but genuinely
# cointegrated) data generator -- recommended for local dev and for demo deploys, since
# real data providers can be flaky or rate-limited.
USE_SYNTHETIC_DATA=true

# Real market data, tier 1: Alpaca Markets (recommended -- free, no credit card, real
# IEX exchange data). Sign up at https://alpaca.markets -> free paper trading account
# gives you both keys immediately. See DEPLOYMENT.md for the full walkthrough.
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=

# Real market data, tier 2 (fallback if Alpaca isn't configured or fails): yfinance,
# unofficial and free, no key needed, but breaks unpredictably -- no env var to set,
# it's just attempted automatically when Alpaca keys are absent.

# JWT signing secret -- MUST be changed to a long random string in production.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-only-insecure-secret-change-me

# CORS -- comma-separated allowed origins. "*" is fine for local dev.
CORS_ORIGINS=*

# Google Sign-In. Optional -- if unset, POST /api/auth/google returns 501 and the
# frontend's Google button simply doesn't render. See DEPLOYMENT.md for setup steps.
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Logging / monitoring
LOG_LEVEL=INFO
ENVIRONMENT=development
# SENTRY_DSN=

# Rate limiting -- only ever set true for local load-testing; never in production.
# DISABLE_RATE_LIMIT=false

# Celery -- true runs tasks synchronously in-process (used by the test suite).
# CELERY_TASK_ALWAYS_EAGER=false
# SCAN_INTERVAL_SECONDS=30
