# Base URL the frontend calls for the API. Leave unset for local dev (Vite proxies
# /api to localhost:8000, see vite.config.ts). Set explicitly when frontend and backend
# are deployed on different domains (e.g. Railway/Render as separate services):
# VITE_API_URL=https://your-backend-domain.up.railway.app/api

# Google OAuth Client ID for "Sign in with Google". Optional -- the Google button
# simply doesn't render if this is unset. See DEPLOYMENT.md for how to create one.
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
